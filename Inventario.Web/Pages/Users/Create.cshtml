@page
@model Inventario.Web.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Registrar usuario";
}

<section class="page-title-block">
    <div>
        <span class="eyebrow">Administración</span>
        <h2 class="h3 mb-2">Registrar usuario</h2>
        <p class="page-subtitle mb-0">Crea una nueva cuenta operativa y asigna su rol inicial dentro del sistema.</p>
    </div>
</section>

<section class="section-card">
    <form method="post" enctype="multipart/form-data" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-md-6">
            <label asp-for="Input.UserName" class="form-label">Usuario</label>
            <input asp-for="Input.UserName" class="form-control" />
            <span asp-validation-for="Input.UserName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.DisplayName" class="form-label">Nombre visible</label>
            <input asp-for="Input.DisplayName" class="form-control" />
            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.Email" class="form-label">Correo</label>
            <input asp-for="Input.Email" class="form-control" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.Password" class="form-label">Contraseña inicial</label>
            <input asp-for="Input.Password" type="password" class="form-control" />
            <div class="form-text">Debe contener al menos 8 caracteres, una mayúscula, una minúscula, un número y un carácter especial.</div>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.Role" class="form-label">Rol</label>
            <select asp-for="Input.Role" class="form-select">
                <option value="ADMIN">ADMIN</option>
                <option value="EMPLEADO">EMPLEADO</option>
            </select>
            <span asp-validation-for="Input.Role" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="AvatarFile" class="form-label">Foto de perfil</label>
            <input asp-for="AvatarFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <div class="form-text">Opcional. Puedes cargar una imagen JPG, PNG o WEBP de hasta 2 MB.</div>
            <span asp-validation-for="AvatarFile" class="text-danger"></span>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Crear usuario</button>
            <a class="btn btn-outline-secondary" asp-page="/Users/Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
