{
  "ConnectionStrings": {
    "DefaultConnection": "REEMPLAZAR_EN_STAGING"
  },
  "Jwt": {
    "Key": "REEMPLAZAR_JWT_STAGING",
    "Issuer": "Inventario.Staging",
    "Audience": "Inventario.Client",
    "AccessTokenMinutes": 20
  },
  "Cors": {
    "AllowedOrigins": [
      "https://staging.inventario.local"
    ]
  },
  "Features": {
    "Swagger": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
